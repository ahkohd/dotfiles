# favourite font
font-family = Berkeley Mono

# alternate font
# font-family = SF Mono

# fallback to Maple Mono
font-family = Maple Mono

font-size = 16

theme = tokyonight-storm

window-padding-x = 20

window-padding-y = 10

# background-opacity = 0.9

# background-blur-radius = 30

keybind = alt+t=new_tab

keybind = alt+s=new_split:right

keybind = alt+x=new_split:down

keybind = alt+i=previous_tab

keybind = alt+o=next_tab

keybind = alt+h=goto_split:left

keybind = alt+l=goto_split:right

keybind = alt+j=goto_split:bottom

keybind = alt+k=goto_split:top

keybind = alt+,=reload_config

keybind = alt+w=close_surface

keybind = alt+enter=toggle_split_zoom

keybind = global:super+t=toggle_quick_terminal

keybind = alt+u=scroll_up

keybind = alt+d=scroll_down

quick-terminal-position = top

quick-terminal-screen = mouse

# mouse-hide-while-typing = true

cursor-style = bar

cursor-style-blink = true

shell-integration = zsh

# custom-shader = shaders/shader.glsl
