{
  "$schema": "https://oyo.dev/theme.schema.json",
  "defs": {
    "bg": "#1d2428",
    "bgAlt": "#2d393d",
    "bgHighlight": "#3d494d",
    "fg": "#f8f9e8",
    "grey": "#6f8788",
    "blue": "#b2cfed",
    "green": "#cae0a7",
