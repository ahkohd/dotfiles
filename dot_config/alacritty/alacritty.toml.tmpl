import = ["~/.config/alacritty/themes/oceanic_next.toml"]

[env]
TERM = "alacritty"

[font]
size = {{ ternary 18 14 (eq .chezmoi.os "darwin") }}

[font.normal]
family = "BitstromWera Nerd Font"
style = "Regular"

[font.bold]
family = "BitstromWera Nerd Font"
style = "Bold"

[font.offset]
x = 0
y = 0

[shell]
program = "zsh"

[window]
opacity = 1
decorations = {{ ternary "\"Buttonless\"" "\"None\"" (eq .chezmoi.os "darwin") }}

[window.dimensions]
columns = 140
lines = 38

[window.padding]
x = 10
y = 5
