font-family = TX-02-AREMU
font-feature = -calt
font-feature = -liga
font-feature = -dlig
font-size = 12
freetype-load-flags = no-hinting
window-padding-balance = true
window-padding-x = 5
window-padding-y = 0
window-colorspace = display-p3
scrollbar = never
theme = evergarden-winter
# alpha-blending = native
window-save-state = always
unfocused-split-opacity = 1
macos-option-as-alt = true
# Ctrl-alt-f leader, tmux-ish
keybind = ctrl+alt+f>n=new_tab
keybind = ctrl+alt+f>shift+backslash=new_split:right
keybind = ctrl+alt+f>-=new_split:down
keybind = ctrl+alt+f>i=previous_tab
keybind = ctrl+alt+f>o=next_tab
keybind = ctrl+alt+f>h=goto_split:left
keybind = ctrl+alt+f>l=goto_split:right
keybind = ctrl+alt+f>j=goto_split:bottom
keybind = ctrl+alt+f>k=goto_split:top
keybind = ctrl+alt+f>w=toggle_tab_overview
keybind = ctrl+alt+f>t=toggle_tab_overview
keybind = ctrl+alt+f>/=toggle_command_palette
keybind = ctrl+alt+f>tab=last_tab
keybind = ctrl+alt+f>space=last_tab
keybind = ctrl+alt+f>r=reload_config
keybind = ctrl+alt+f>x=close_surface
keybind = ctrl+alt+f>shift+x=close_tab
keybind = ctrl+alt+f>enter=toggle_split_zoom
keybind = ctrl+alt+f>u=scroll_page_up
keybind = ctrl+alt+f>d=scroll_page_down
keybind = global:cmd+alt+ctrl+shift+enter=toggle_quick_terminal
quick-terminal-screen = mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
cursor-style = bar
cursor-style-blink = true
shell-integration = zsh
command = zsh
macos-icon = custom-style
macos-icon-frame = plastic
macos-titlebar-style = transparent
