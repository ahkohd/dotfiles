[commit]
 gpgsign = true

[core]
editor = nvim
pager = delta

[interactive]
diffFilter = delta --color-only

[delta]
    dark = true
    syntax-theme = Nord
    line-numbers = true
    side-by-side = true
    file-decoration-style = none
    file-added-label = [+]
    file-copied-label = [==]
    file-modified-label = [*]
    file-removed-label = [-]
    file-renamed-label = [->]
    zero-style = syntax
    blame-code-style = syntax
    merge-conflict-begin-symbol = ~
    merge-conflict-end-symbol = ~

[merge]
conflictstyle = diff3

[diff]
colorMoved = default
