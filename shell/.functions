# preview markdown that looks like GitHub
md() {
    if ! command -v gh &>/dev/null; then
        echo "Error: gh (GitHub CLI) is not installed"
        return 1
    fi

    if ! gh extension list | grep -q "yusukebe/gh-markdown-preview"; then
        echo "Error: gh-markdown-preview extension is not installed. Install it with: gh extension install yusukebe/gh-markdown-preview"
        return 1
    fi

    if ! command -v fd &>/dev/null; then
        echo "Error: fd is not installed"
        return 1
    fi

    if ! command -v fzf &>/dev/null; then
        echo "Error: fzf is not installed"
        return 1
    fi

    local file
    file="$(fd -e md -e markdown | fzf)" || return 1
    [ -z "$file" ] && return 0
    gh markdown-preview "$file" &
}

# jj navigation functions
j-() {
    local count=${1:-1}
    local suffix=$(printf '%*s' "$count" | tr ' ' '-')
    jj edit "@${suffix}" --ignore-immutable
}

j+() {
    local count=${1:-1}
    local suffix=$(printf '%*s' "$count" | tr ' ' '+')
    jj edit "@${suffix}" --ignore-immutable
}

ta() {
    local session
    if [ -n "$1" ]; then
        session="$1"
    else
        session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | fzf --prompt="attach> ") || return
    fi
    if [ -n "$TMUX" ]; then
        tmux switch-client -t "$session"
    else
        tmux attach-session -t "$session"
    fi
}

zk() {
    if [[ -z "$ZMX_SESSION" ]]; then
        echo "not in zmx"
        return 1
    fi

    zmx kill "$ZMX_SESSION" --force
}

za() {
    local display output query key selected session_name rc

    while true; do
        display=$(zmx list 2>/dev/null | while IFS=$'\t' read -r name pid clients created dir; do
            name=${name#*name=}
            pid=${pid#*pid=}
            clients=${clients#*clients=}
            dir=${dir#*start_dir=}
            printf "%-20s  pid:%-8s  clients:%-2s  %s\n" "$name" "$pid" "$clients" "$dir"
        done)

        output=$({ [[ -n "$display" ]] && echo "$display"; } | fzf \
            --print-query \
            --expect=ctrl-n,ctrl-k \
            --height=80% \
            --reverse \
            --prompt="zmx> " \
            --header="Enter: select | Ctrl-N: create new | Ctrl-K: kill" \
            --preview='zmx history {1}' \
            --preview-window=right:60%:follow)
        rc=$?

        query=$(echo "$output" | sed -n '1p')
        key=$(echo "$output" | sed -n '2p')
        selected=$(echo "$output" | sed -n '3p')

        if [[ "$key" == "ctrl-k" && -n "$selected" ]]; then
            session_name=$(echo "$selected" | awk '{print $1}')
            zmx kill "$session_name" --force
            continue
        elif [[ "$key" == "ctrl-n" && -n "$query" ]]; then
            session_name="$query"
        elif [[ $rc -eq 0 && -n "$selected" ]]; then
            session_name=$(echo "$selected" | awk '{print $1}')
        elif [[ -n "$query" ]]; then
            session_name="$query"
        else
            return 130
        fi

        zmx attach "$session_name"
        return
    done
}



