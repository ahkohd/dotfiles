shell:
  program: zsh
env:
  TERM: alacritty
window:
  decorations: {{ ternary "Buttonless" "None" (eq .chezmoi.os "darwin") }}
  dimensions:
    columns: 140
    lines: 38
  opacity: 1
  padding:
    x: 10
    y: 5
font:
  size: {{ ternary 18 14 (eq .chezmoi.os "darwin") }}
  normal:
    ## family: "BerkeleyMono Nerd Font Plus Font Awesome Plus Octicons Plus Codicons Plus Material Design Icons"
    family: "BitstormWera Nerd Font"
    style: Regular
  bold:
    ## family: "BerkeleyMono Nerd Font Plus Font Awesome Plus Octicons Plus Codicons Plus Material Design Icons"
    family: "BitstormWera Nerd Font"
    style: Bold
  ## italic:
  ##   ## family: "BerkeleyMono Nerd Font Plus Font Awesome Plus Octicons Plus Codicons Plus Material Design Icons"
  ##   family: "BitstormWera Nerd Font"
  ##   style: Italic
  ## bold_italic:
  ##   ## family: "BerkeleyMono Nerd Font Plus Font Awesome Plus Octicons Plus Codicons Plus Material Design Icons"
  ##   family: "BitstormWera Nerd Font"
  ##   style: Bold Italic
  offset:
    x: 0
    y: 0
import:
  - ~/.config/alacritty/themes/mellow.yml
