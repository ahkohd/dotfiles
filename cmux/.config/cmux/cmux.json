  "shortcuts": {
    "bindings": {
      "prevSurface": ["ctrl+alt+f", "i"],
      "nextSurface": ["ctrl+alt+f", "o"],
      "newSurface": ["ctrl+alt+f", "n"],
      "focusLeft": ["ctrl+alt+f", "h"],
      "focusRight": ["ctrl+alt+f", "l"],
      "focusDown": ["ctrl+alt+f", "j"],
      "focusUp": ["ctrl+alt+f", "k"],
      "splitRight": ["ctrl+alt+f", "shift+\\"],
      "splitDown": ["ctrl+alt+f", "-"],
      "toggleSplitZoom": ["ctrl+alt+f", "enter"],
      "canvasOverview": ["ctrl+alt+f", "w"],
      "commandPalette": ["ctrl+alt+f", "/"],
      "reloadConfiguration": ["ctrl+alt+f", "r"],
      "closeTab": ["ctrl+alt+f", "x"],
      "toggleSidebar": ["ctrl+alt+f", "s"],
      "goToWorkspace": ["ctrl+alt+f", "p"],
      "prevSidebarTab": ["ctrl+alt+f", "a"],
      "nextSidebarTab": ["ctrl+alt+f", ";"],
      "newTab": ["ctrl+alt+f", "shift+p"]
    }
  },

