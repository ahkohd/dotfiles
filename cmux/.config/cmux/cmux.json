{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "app": {
    "confirmQuit": "never",
    "sendAnonymousTelemetry": false,
    "preferredEditor": "nvim",
    "openSupportedFilesInCmux": false
  },

  "fileExplorer": {
    "doubleClickAction": "preferredEditor"
  },

  "markdown": {
    "fontFamily": "TX-02-AREMU"
  },

  "sidebar": {
    "watchGitStatus": true,
    "showPullRequests": true,
    "showPorts": true,
    "showProgress": true,
    "showLog": true,
    "pathLastSegmentOnly": true,
    "showSSH": true
  },

  "notifications": {
    "unreadPaneRing": false
  },

  "diffViewer": {
    "defaultLayout": "split"
  },

  "commands": [
    {
      "name": "oyo diff",
      "keywords": ["oy", "oyo", "diff"],
      "workspace": {
        "name": "oyo",
        "cwd": ".",
        "layout": {
          "pane": {
            "surfaces": [
              { "type": "terminal", "name": "oyo", "command": "oy" }
            ]
          }
        }
      }
    }
  ],

