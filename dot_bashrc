#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

PS1='[\u@\h \W]\$ '

# SSH Agent bind address
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"

export PATH="/usr/local/bin:$PATH"

export PATH=$PATH:~/.cargo/bin

# Homebrew for macOS
export PATH="/opt/homebrew/bin:$PATH"

export PATH="$HOME/neovim/bin:$PATH"

# Fly.io CLI
export FLYCTL_INSTALL="/home/var/.fly"

export PATH="$FLYCTL_INSTALL/bin:$PATH"

export EDITOR=nvim

alias cm=chezmoi
alias cme='chezmoi edit'
alias cma='chezmoi apply'
alias cmd='chezmoi diff'
alias cmu='chezmoi update'
alias dev=~/developer/personal
alias grep='grep --color=auto'
alias gs="git status"
alias gp="git pull"
alias gP="git push"
alias nv="neovide"
alias wm=Hyprland
alias ls='exa --icons'
alias ll='exa -alh'
alias tree='exa --tree --level=4'
alias pbcopy=wl-copy
alias pbpaste=wl-paste
alias cat='bat --theme="Embark"'
alias f="fzf --preview 'bat --theme=Embark --color=always --style=header,grid --line-range :500 {}'"
alias fo='open "$(f)"'
alias fe='nvim "$(f)"'
alias x=exit
alias cht=~/.config/bin/.local/scripts/tmux-cht.sh
alias gpg-check="gpg --decrypt ~/test.gpg"

export MANPAGER="sh -c 'col -bx | bat -l man -p'"

. "$HOME/.cargo/env"

# workaround to make GPG work with pinentry
export GPG_TTY=$(tty)

# setup fnm
eval "$(fnm env --use-on-cd)"

# setup fzf
[ -z "$ZSH_NAME" ] && [ -f ~/.fzf.bash ] && source ~/.fzf.bash
